<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="panda_materials">
    <material name="red">
        <color rgba="1 0 0 1" />
    </material>
    <material name="grey">
        <color rgba="0.75 0.75 0.75 1" />
    </material>
    <material name="green">
        <color rgba="0 1 0 1" />
    </material>
    <material name="blue">
        <color rgba="0 0 1 1" />
    </material>
</robot>
